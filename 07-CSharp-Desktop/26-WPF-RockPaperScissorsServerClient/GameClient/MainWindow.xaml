<Window x:Class="GameClient.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:GameClient"
        mc:Ignorable="d"
        Title="Rock Paper Scissors Player" Height="450" Width="800">
    <StackPanel Margin="10">
        <TextBlock Text="PLAYER TERMINAL" FontSize="18" HorizontalAlignment="Center"/>

        
        <Label Content="Server IP:"/>
        <TextBox x:Name="txtIP" Text="127.0.0.1"/>
        <Button x:Name="btnConnect" Content="CONNECT TO GAME" Margin="0,5" Click="btnConnect_Click"/>

        <Separator Margin="0,10"/>

      
        <TextBlock Text="CHOOSE YOUR WEAPON:" HorizontalAlignment="Center" FontWeight="Bold"/>
        <UniformGrid Columns="3" Height="60" Margin="0,10">
            
            <Button x:Name="btnRock" Content="🪨 ROCK" Click="btnRock_Click"/>
            <Button x:Name="btnPaper" Content="📜 PAPER" Click="btnPaper_Click"/>
            <Button x:Name="btnScissors" Content="✂️ SCISSORS" Click="btnScissors_Click"/>
        </UniformGrid>

        <TextBlock x:Name="lblStatus" Text="Status: Not Connected" 
               Foreground="Red" HorizontalAlignment="Center" Margin="10"/>
    </StackPanel>
</Window>

