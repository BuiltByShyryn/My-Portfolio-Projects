<Window x:Class="GameServer.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:GameServer"
        mc:Ignorable="d"
        Title="Puzzle Server 413" Height="600" Width="950" WindowStartupLocation="CenterScreen">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
            <Label Content="IP:" VerticalAlignment="Center"/>
            <ComboBox x:Name="cbIpList" Width="180" Margin="0,0,10,0"/>
            <Label Content="Port:" VerticalAlignment="Center"/>
            <TextBox x:Name="txtPort" Width="80" Text="12345" Margin="0,0,10,0"/>
            <Label Content="Max clients:" VerticalAlignment="Center"/>
            <TextBox x:Name="txtMaxClients" Width="60" Text="10" Margin="0,0,10,0"/>
            <Button x:Name="btnStartStop" Width="140" Height="32" Content="Start" Click="btnStartStop_Click"/>
        </StackPanel>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="240"/>
                <ColumnDefinition Width="240"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <GroupBox Header="Connected Clients" Margin="0,0,10,0">
                <ListBox x:Name="lstClients"/>
            </GroupBox>

            <GroupBox Header="Stored Puzzles" Grid.Column="1" Margin="0,0,10,0">
                <ListBox x:Name="lstPuzzles"/>
            </GroupBox>

            <GroupBox Header="Server Log" Grid.Column="2">
                <TextBox x:Name="txtLog"
                         IsReadOnly="True"
                         TextWrapping="Wrap"
                         AcceptsReturn="True"
                         VerticalScrollBarVisibility="Auto"/>
            </GroupBox>
        </Grid>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
            <Button x:Name="btnDeletePuzzle" Width="110" Height="30" Margin="0,0,10,0" Content="Delete Puzzle" Click="btnDeletePuzzle_Click"/>
            <Button x:Name="btnSaveLog" Width="110" Height="30" Margin="0,0,10,0" Content="Save Log" Click="btnSaveLog_Click"/>
            <Button x:Name="btnClearLog" Width="110" Height="30" Margin="0,0,10,0" Content="Clear Log" Click="btnClearLog_Click"/>
            <Button x:Name="btnClose" Width="110" Height="30" Content="Close" Click="btnClose_Click"/>
        </StackPanel>
    </Grid>
</Window>
