<Window x:Class="HorseRaceSimulator.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:HorseRaceSimulator"
        mc:Ignorable="d"
        Title="MainWindow" Height="450" Width="800">
    <StackPanel Margin="20">
        <TextBlock Text="🐎 HORSE RACE SIMULATOR 🐎" FontSize="20" HorizontalAlignment="Center" Margin="0,0,0,10"/>

        <ProgressBar Name="pbHorse1" Height="25" Margin="5"/>
        <ProgressBar Name="pbHorse2" Height="25" Margin="5"/>
        <ProgressBar Name="pbHorse3" Height="25" Margin="5"/>
        <ProgressBar Name="pbHorse4" Height="25" Margin="5"/>
        <ProgressBar Name="pbHorse5" Height="25" Margin="5"/>

        <Button Content="START RACE" Click="btnStart_Click" Height="40" Margin="10" Background="LightGreen"/>

        <TextBlock Text=" RESULTS " HorizontalAlignment="Center" Margin="10,10,0,0"/>
        <ListBox Name="lstResults" Height="100" Margin="5"/>
    </StackPanel>
</Window>
