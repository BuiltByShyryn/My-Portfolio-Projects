<Window x:Class="ServerWPF.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Currency Server PRO" Height="450" Width="600" Background="#F0F0F0">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Orientation="Horizontal" Grid.Row="0" Margin="0,0,0,10">
            <Button Content="▶ START" Width="100" Height="30" Margin="5" Background="#4CAF50" Foreground="White" Click="StartServer_Click"/>
            <Button Content="■ STOP" Width="100" Height="30" Margin="5" Background="#F44336" Foreground="White" Click="StopServer_Click"/>
            <TextBlock Text="Max Clients:" VerticalAlignment="Center" Margin="10,0,5,0"/>
            <TextBox x:Name="txtMaxClients" Text="5" Width="40" Height="25" VerticalContentAlignment="Center"/>
        </StackPanel>

        <GroupBox Header="Server Activity Log" Grid.Row="1">
            <TextBox x:Name="txtLog" IsReadOnly="True" VerticalScrollBarVisibility="Auto" Background="Black" Foreground="#00FF00" FontFamily="Consolas"/>
        </GroupBox>

        <StatusBar Grid.Row="2" Background="LightGray">
            <TextBlock x:Name="lblStatus" Text="Status: Offline"/>
        </StatusBar>
    </Grid>
</Window>