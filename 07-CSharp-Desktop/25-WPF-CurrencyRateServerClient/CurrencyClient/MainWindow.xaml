<Window x:Class="ClientWPF.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Client" Height="300" Width="300">
    <StackPanel Margin="20">
        <TextBlock Text="Request (USD EUR):" Margin="0,5"/>
        <TextBox x:Name="txtRequest" Text="USD EUR" Height="30"/>

        <Button Content="SEND" Height="40" Margin="0,20" Click="Send_Click"/>

        <TextBlock Text="Server Response:" Margin="0,10,0,0"/>
        <TextBlock x:Name="txtResponse" FontSize="18" Foreground="Blue" FontWeight="Bold"/>
    </StackPanel>
</Window>