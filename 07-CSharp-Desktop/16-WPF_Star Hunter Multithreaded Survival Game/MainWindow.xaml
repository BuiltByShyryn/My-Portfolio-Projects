<Window x:Class="StarHunter_Exam.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:StarHunter_Exam"
        mc:Ignorable="d"
        Title="MainWindow" Height="450" Width="800">
    <Grid Background="#FFB6C1">
        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
            <TextBlock Text="🐰 STAR HUNTER 2026 🥕" FontSize="36" FontWeight="Bold" Foreground="White" Margin="0,0,0,30">
                <TextBlock.Effect>
                    <DropShadowEffect BlurRadius="5" ShadowDepth="2"/>
                </TextBlock.Effect>
            </TextBlock>

            <Button x:Name="btnStart" Content="START GAME 🐮" Width="200" Height="50" FontSize="20" Background="White" Cursor="Hand" Click="btnStart_Click"/>
            <Button x:Name="btnExit" Content="EXIT" Width="200" Height="40" FontSize="16" Margin="0,10,0,0" Background="#FFFFE4E1" Click="btnExit_Click"/>

            <TextBlock Text="Don't let the cows get the carrots!" HorizontalAlignment="Center" Margin="0,20,0,0" Foreground="White" FontStyle="Italic"/>
        </StackPanel>
    </Grid>
</Window>
