<Window x:Class="StarHunter_Exam.GameWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:StarHunter_Exam"
        mc:Ignorable="d"
        Title="GameWindow" Height="600" Width="900" WindowStartupLocation="CenterScreen">

    <DockPanel Background="#FFF0FFF0">
        <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Background="#FFFFE4E1" Height="70">
            <Border Background="#FFFFF5EE" 
        CornerRadius="10" 
        Margin="20,10" 
        Padding="15,5" 
        Width="280">

                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock x:Name="lblPlayerScore" 
                   Text="🐰 Bunny: 0" 
                   Foreground="#FF5DADE2" 
                   FontSize="22" 
                   FontWeight="Bold"/>

                    <TextBlock x:Name="lblOuch" 
                   Text=" ❗ WAH!" 
                   Foreground="OrangeRed" 
                   FontSize="22" 
                   FontWeight="Bold" 
                   Visibility="Collapsed"/>
                </StackPanel>
            </Border>

            <Border Background="#FFFFF5EE" CornerRadius="10" Margin="10,10" Padding="15,5">
                <TextBlock x:Name="lblBotScore" Text="🐮 Cows: 0" Foreground="MediumPurple" FontSize="22" VerticalAlignment="Center" FontWeight="Bold"/>
            </Border>

            <StackPanel VerticalAlignment="Center" Margin="40,0">
                <TextBlock Text="✨ HARVEST PROGRESS ✨" Foreground="#FF8E44AD" FontSize="12" HorizontalAlignment="Center" Margin="0,0,0,5" FontWeight="Bold"/>
                <ProgressBar x:Name="progGame" Width="250" Height="20" Maximum="50" Background="White" Foreground="#FFD2B4DE">
                    <ProgressBar.Effect>
                        <DropShadowEffect BlurRadius="5" ShadowDepth="1" Opacity="0.3"/>
                    </ProgressBar.Effect>
                </ProgressBar>
            </StackPanel>
        </StackPanel>

        <Canvas x:Name="GameCanvas" 
        Background="#FFF9E3" 
        Width="900" 
        Height="450">
        </Canvas>
    </DockPanel>
</Window> 
