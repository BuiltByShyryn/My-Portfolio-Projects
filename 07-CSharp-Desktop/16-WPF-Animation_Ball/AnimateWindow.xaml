<Window x:Class="AnimationWpf.AnimateWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:AnimationWpf"
        mc:Ignorable="d"
        Title="AnimateWindow" Height="600" Width="500">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition  Height="3*"/>
            <RowDefinition Height="1*"/>
        </Grid.RowDefinitions>
        <Canvas x:Name ="canvas" Grid.Row="0" Margin="5"></Canvas>
        
        <StackPanel Grid.Row="1">
            <Button Click ="Button_Click_Add" Content="Add threads" Margin="5" Padding="5"></Button>
            <Button Click ="Button_Click_Pause" Content="Pausa threads" Margin="5" Padding="5"></Button>
            <Button Click ="Button_Click_Resume" Margin="5" Padding="5" Content="Continue"></Button>
        </StackPanel>
    </Grid>
</Window>
