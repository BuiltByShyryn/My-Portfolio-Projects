<Window x:Class="DancingProgressBars.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:DancingProgressBars"
        mc:Ignorable="d"
        Title="MainWindow" Height="450" Width="800">
    <StackPanel Margin="20">
        <TextBlock Text="How many dancing bars?" Margin="0,0,0,5"/>
        <TextBox Name="txtBarCount" Text="5" Width="50" HorizontalAlignment="Left" Margin="0,0,0,10"/>
        <Button Name="btnStart" Content="START THE DANCE!" Click="btnStart_Click" Height="30" Margin="0,0,0,10"/>

        <StackPanel Name="BarsContainer"/>
    </StackPanel>
</Window>
